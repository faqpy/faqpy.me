---
import '../styles/global.css';
import Header from '../components/Header.astro';
import { Icon } from 'astro-icon/components';
---

<html lang="en">

<head>
    <Header />
</head>

<body>
    <main class="layout-main">
        <div class="card centered-card">
            <div class="card-icon-wrapper">
                <m3e-shape name="soft-burst" class="m3e-icon-bg" style="--m3e-shape-container-color:var(--md-sys-color-primary);"></m3e-shape>
                <Icon name="material-symbols:cloud-off" class="card-icon-foreground" />
            </div>
            <h1 class="profile-title">error 404</h1>
            <p class="card-subtitle">page not found</p>
            <div class="card-article">
                <p>please check the url and try again. if you think this is a mistake, please contact me!</p>
            </div>
            <div class="card-actions card-buttons">
                <a href="mailto:hi@faqpy.me" class="btn-primary btn-primary-medium">mail me <Icon name="material-symbols:open-in-new" class="card-icon-foreground" /></a>
                <a href="/" class="btn-primary btn-primary-medium">home</a>
            </div>
        </div>
    </main>
    <script>
        import '@m3e/web/shape';
    </script>
</body>

</html>