---
import '../styles/global.css';
import Header from '../components/Header.astro';
import CustomEmoji from '../components/CustomEmoji.astro';
import FooterMusic from '../components/FooterMusic.astro';
import EnterScreen from '../components/EnterScreen.astro';
import { Icon } from 'astro-icon/components';
---

<html lang="en">

<head>
    <Header />
</head>

<body>
    <EnterScreen />
    <div id="main-wrapper" style="display: none; opacity: 0; transition: opacity 0.5s ease-in;">
        <main class="layout-main">

            <section class="hero-banner">
                <video autoplay loop muted playsinline class="hero-video-bg">
                    <source src="/assets/videos/ddf-c.webm" type="video/webm" />
                </video>
                <div class="hero-video-overlay"></div>
                <div class="hero-banner-content">
                    <div class="profile-content">
                        <img src="/assets/images/hoshikawa-sara.webp" class="profile-avatar" alt="faqpy" draggable="false" />
                        <h1 class="profile-title">faqpy</h1>
                        <p class="profile-bio">(a.k.a witchie)</p>
                        
                        <div class="profile-socials">
                            <a id="social-github" href="https://github.com/faqpy" target="_blank" rel="noreferrer noopener" class="social-icon" aria-label="github">
                                <Icon name="simple-icons:github" />
                            </a>
                            <m3e-tooltip for="social-github" position="below">github</m3e-tooltip>
                            <a id="social-discord" href="https://discord.com/users/277867160796397568" target="_blank" rel="noreferrer noopener" class="social-icon" aria-label="discord">
                                <Icon name="simple-icons:discord" />
                            </a>
                            <m3e-tooltip for="social-discord" position="below">discord</m3e-tooltip>
                            <a id="social-bsky" href="https://bsky.app/profile/faqpy.me" target="_blank" rel="noreferrer noopener" class="social-icon" aria-label="bluesky">
                                <Icon name="simple-icons:bluesky" />
                            </a>
                            <m3e-tooltip for="social-bsky" position="below">bluesky</m3e-tooltip>
                            <a id="social-twitter" href="https://x.com/faqpy" target="_blank" rel="noreferrer noopener" class="social-icon" aria-label="twitter">
                                <Icon name="simple-icons:twitter" />
                            </a>
                            <m3e-tooltip for="social-twitter" position="below">twitter</m3e-tooltip>
                            <a id="social-ig" href="https://instagram.com/faqpy" target="_blank" rel="noreferrer noopener" class="social-icon" aria-label="instagram">
                                <Icon name="simple-icons:instagram" />
                            </a>
                            <m3e-tooltip for="social-ig" position="below">instagram</m3e-tooltip>
                        </div>
                    </div>
                </div>
                <button id="scroll-down-btn" class="btn-primary btn-primary-blur" style="position: absolute; bottom: 24px; right: 24px; color: var(--md-sys-color-primary); z-index: 10;" aria-label="scroll down">
                    scroll <Icon name="material-symbols:keyboard-arrow-down" class="btn-icon" />
                </button>
                <m3e-tooltip for="scroll-down-btn" position="before">go down!</m3e-tooltip>
            </section>

            <section class="content-section">
                <nav class="card-nav" aria-label="jump to site sections">
                    <a href="#about">about</a>
                    <a href="#friends">friends</a>
                    <a href="#games">mmmgemes</a>
                    <a href="#notes">notes</a>
                    <a href="#newspaper">news</a>
                    <a href="#lastfm">music</a>
                </nav>
                <div class="content-layout">

                    <div class="content-column">

                        <section class="card card-image-bg" id="games" style="--card-bg-url: url('/assets/images/dr-c5-sunset.webp');" id="about">
                            <div class="card-icon-wrapper">
                                <m3e-shape name="soft-burst" class="m3e-icon-bg" style="--m3e-shape-container-color:var(--md-sys-color-primary);"></m3e-shape>
                                <Icon name="material-symbols:waving-hand" class="card-icon-foreground" />
                            </div>
                            <div class="profile-details about-card">
                                <h1 class="profile-title"><span>faqpy</span> です!</h1>
                                <p class="card-subtitle">(a.k.a witchie)</p>
                                <ul class="profile-description">
                                    <li>heya, i'm faqpy <CustomEmoji src="/assets/emojis/miauWhat.webp" name="miau" /></li>
                                    <li>a self-taught web developer</li>
                                    <li>頭悪いですｗ</li>
                                </ul>
                                <img src="/assets/images/ralsei-plush-nurse.webp" alt="ralsei heart" class="card-image" style="width: 80px; transform: rotate(180deg);" draggable="false" />
                            </div>
                            <div class="statuscafe" style="margin-top: 0;">
                                <div id="statuscafe-username"></div>
                                <div id="statuscafe-content"></div>
                            </div>
                            <script src="https://status.cafe/current-status.js?name=faqpy" defer></script>
                        </section>

                        <section class="card" id="friends">
                            <div class="card-icon-wrapper">
                                <m3e-shape name="6-sided-cookie" class="m3e-icon-bg" style="--m3e-shape-container-color:var(--md-sys-color-primary);"></m3e-shape>
                                <Icon name="material-symbols:group" class="card-icon-foreground" />
                            </div>
                            <h2 class="card-heading">friends</h2>
                            <p class="card-subtitle">some cool people :3</p>
                            <div class="card-article eexto-grid">
                                <a href="https://twixxt.vercel.app/" target="_blank" rel="noreferrer noopener">
                                    <img src="/assets/buttons/twixxty.gif" alt="twixxty" draggable="false" class="eexto" />
                                </a>
                                <a href="https://www.nicovideo.jp/watch/sm11509720" target="_blank" rel="noreferrer noopener">
                                    <img src="/assets/buttons/miau.png" alt="miau" draggable="false" class="eexto" />
                                </a>
                                <a href="/player">
                                    <img src="/assets/buttons/player-eexto.gif" alt="cute" draggable="false" class="eexto" />
                                </a>
                            </div>
                            <hr class="card-divider">
                            <div class="faqpy-button">
                                <button class="btn-link" id="copy-btn" aria-label="copy embed code">
                                    <img src="/button.png" alt="faqpy button" draggable="false" class="eexto" />
                                </button>
                                <span id="copy-label" style="text-align:center;">click to copy</span>
                            </div>
                        </section>

                        <section class="card card-image-bg" id="games" style="--card-bg-url: url('/assets/images/sonic-and-miku.webp');">
                            <div class="card-icon-wrapper">
                                <m3e-shape name="gem" class="m3e-icon-bg" style="--m3e-shape-container-color:var(--md-sys-color-primary);"></m3e-shape>
                                <Icon name="material-symbols:gamepad" class="card-icon-foreground" />
                            </div>
                            <h2 class="card-heading">i play games <CustomEmoji src="/assets/emojis/susie-eager.webp" name="susie-eager" /></h2>
                            <p class="card-subtitle">although i rarely play any games now, mmmgemes</p>
                            <div class="profile-socials" style="justify-content: flex-start; margin-top: 4px;">
                                <a id="game-steam" href="https://steamcommunity.com/id/schizofuck" target="_blank" rel="noreferrer noopener" class="social-icon" aria-label="steam">
                                    <Icon name="simple-icons:steam" />
                                </a>
                                <m3e-tooltip for="game-steam" position="below">steam</m3e-tooltip>
                                <a id="game-roblox" href="https://www.roblox.com/users/802402672/profile" target="_blank" rel="noreferrer noopener" class="social-icon" aria-label="roblox">
                                    <Icon name="simple-icons:roblox" />
                                </a>
                                <m3e-tooltip for="game-roblox" position="below">roblox</m3e-tooltip>
                                <a id="game-namemc" href="https://namemc.com/profile/faqpy.1" target="_blank" rel="noreferrer noopener" class="social-icon" aria-label="minecraft">
                                    <Icon name="simple-icons:namemc" style="border-radius: 10px;" />
                                </a>
                                <m3e-tooltip for="game-namemc" position="below">minecraft</m3e-tooltip>
                                <a id="game-osu" href="https://osu.ppy.sh/users/19575078" target="_blank" rel="noreferrer noopener" class="social-icon" aria-label="osu!">
                                    <Icon name="simple-icons:osu" />
                                </a>
                                <m3e-tooltip for="game-osu" position="below">osu!</m3e-tooltip>
                                <a id="game-ytm" href="https://music.youtube.com/@schizofuck" target="_blank" rel="noreferrer noopener" class="social-icon" aria-label="youtube music">
                                    <Icon name="simple-icons:youtubemusic" />
                                </a>
                                <m3e-tooltip for="game-ytm" position="below">youtube music</m3e-tooltip>
                            </div>

                        </section>

                        <section class="card" id="art">
                            <img src="/assets/gifs/papyrus-watering.webp" class="card-image" style="object-fit: contain;" alt="papyrus watering" draggable="false" />
                        </section>

                    </div>

                    <div class="content-column">

                        <section class="card card-image-bg" style="--card-bg-url: url('/assets/images/osaka.webp');" id="notes">
                            <div class="card-icon-wrapper icon-secondary">
                                <m3e-shape name="burst" class="m3e-icon-bg" style="--m3e-shape-container-color:var(--md-sys-color-secondary-container);"></m3e-shape>
                                <Icon name="material-symbols:edit-note" class="card-icon-foreground" />
                            </div>
                            <h2 class="card-heading">notebook</h2>
                            <p class="card-subtitle">notes to myself which i never read in the first place ;p</p>
                            <div class="card-actions card-buttons">
                                <a href="/player" class="btn-primary btn-primary-blur" style="color: var(--md-sys-color-primary);">
                                    chill out <Icon name="material-symbols:play-circle" class="btn-icon" />
                                </a>
                                <a href="/notes" class="btn-primary btn-primary-blur" style="color: var(--md-sys-color-primary);">
                                    open notes <Icon name="material-symbols:open-in-new" class="btn-icon" />
                                </a>
                            </div>
                        </section>

                        <section class="card" id="newspaper">
                            <div class="card-icon-wrapper icon-secondary">
                                <m3e-shape name="square" class="m3e-icon-bg" style="--m3e-shape-container-color:var(--md-sys-color-secondary-container);"></m3e-shape>
                                <Icon name="material-symbols:newspaper" class="card-icon-foreground" />
                            </div>
                            <h2 class="card-heading">newspaper</h2>
                            <p class="card-subtitle">Saturday, July 11th, 2026</p>
                            <div class="card-actions card-buttons" style="margin-top: 1rem;">
                                <button class="btn-primary btn-primary-blur" style="color: var(--md-sys-color-primary);">
                                    <m3e-dialog-trigger for="news-dialog" style="display: flex; align-items: center; gap: 8px;">2026 <Icon name="material-symbols:menu-book" class="btn-icon" /></m3e-dialog-trigger>
                                </button>
                                <button class="btn-primary btn-primary-blur" style="color: var(--md-sys-color-primary);">
                                    <m3e-dialog-trigger for="news-dialog-2" style="display: flex; align-items: center; gap: 8px;">3026 <Icon name="material-symbols:image" class="btn-icon" /></m3e-dialog-trigger>
                                </button>
                            </div>
                            
                            <m3e-dialog id="news-dialog" dismissible>
                                <span slot="header">jp is not for the weak</span>
                                <div class="card-article" style="color: var(--md-sys-color-on-surface); font-family: var(--font-body); padding-bottom: 1rem;">
                                    <p>studying japanese through anki was really fun but it gets quite boring really quickly, so boring that you actually start skipping lessons. this is a problem because it makes it really hard to get back into the habit of studying. i guess i'll just have to find a way to make it more fun and interesting so that i can keep up with it again. <CustomEmoji src="/assets/emojis/tenna-dance.webp" name="tenna-dance" /></p>
                                    <img src="/assets/gifs/susie-eat-melon.webp" alt="susie eating melon" class="card-image" style="object-fit: contain; width: 80px;" draggable="false" />
                                    <p>if you're reading this and have any suggestions on how to make studying japanese more fun and interesting, please let me know! i'd really appreciate it, really. <CustomEmoji src="/assets/emojis/ralsei-tata.webp" name="ralsei-tata" /></p>
                                    <img src="/assets/gifs/wobble-fw.webp" alt="wobbling" draggable="false" style="width: 80px;" />
                                </div>
                            </m3e-dialog>
                            <m3e-dialog id="news-dialog-2" dismissible>
                                <span slot="header">im sick n tried</span>
                                <div class="card-article" style="color: var(--md-sys-color-on-surface); font-family: var(--font-body); padding-bottom: 1rem;">
                                    <img src="/assets/images/kris-bloxxy.webp" style="height: auto; width: 100%; display: block; max-width: 480px; border-radius: var(--list-radius);" alt="kris" draggable="false"  />
                                </div>
                            </m3e-dialog>

                            <img src="/assets/images/cunny.webp" class="card-image" alt="miau miau bunny" draggable="false" />
                            <div class="news-marquee">
                                <marquee behavior="scroll" direction="left"><span style="font-weight: bold; color: var(--md-sys-color-error-container);">breaking news:</span> miau miau miau? MIAU! miau miau maaouu mrrp miau! miau purr &#58;3</marquee>
                            </div>
                        </section>

                        <section class="card card-image-bg" id="lastfm">
                            <div class="card-icon-wrapper icon-secondary">
                                <m3e-shape name="circle" class="m3e-icon-bg" style="--m3e-shape-container-color:var(--md-sys-color-secondary-container);"></m3e-shape>
                                <Icon name="material-symbols:music-note" class="card-icon-foreground" />
                            </div>
                            <h2 class="card-heading">now playing</h2>
                            <p class="card-subtitle" id="lastfm-status">loading...</p>
                            <div class="lastfm-info" id="lastfm-track">
                                <a class="lastfm-song" id="lastfm-song" href="#" target="_blank" rel="noreferrer noopener"></a>
                                <a class="lastfm-artist" id="lastfm-artist" href="#" target="_blank" rel="noreferrer noopener"></a>
                            </div>
                        </section>

                        <section class="card" id="webrings">
                            <h2 class="card-heading">webrings</h2>
                            <div class="webring-list">
                                <div id='gfdkris' class="webring-entry">
                                    <script type="text/javascript" src="https://fabstarotcorner.neocities.org/webring/onionring-variables.js"></script>
                                    <script type="text/javascript" src="https://fabstarotcorner.neocities.org/webring/onionring-widget.js"></script>
                                </div>
                                <div class="webring-entry">
                                    <script is:inline src="https://dazaisfunpalace.nekoweb.org/pjsk.js" data-widget="title"></script>
                                    <script>
                                        document.addEventListener("DOMContentLoaded", () => {
                                            const replaceImg = document.getElementById("replace") as HTMLImageElement;
                                            if (replaceImg) {
                                                replaceImg.src = "/assets/images/Rin_Fan_Title_JP.webp";
                                            }
                                        });
                                    </script>
                                </div>
                            </div>
                        </section>

                    </div>

                </div>
            </section>
        </main>
        <footer class="site-footer">
            <div class="footer-container">
                <div class="footer-card">
                    <div class="footer-content">
                        <div class="footer-links">
                            <a id="footer-mail" href="mailto:hi@faqpy.me" aria-label="contact me" class="footer-link">mail</a>
                            <m3e-tooltip for="footer-mail" position="above">hi@faqpy.me</m3e-tooltip>
                            <span class="footer-separator">✧</span>
                            <a id="footer-license" href="/license" class="footer-link">license</a>
                            <m3e-tooltip for="footer-license" position="above">copyright and usage</m3e-tooltip>
                            <span class="footer-separator">✧</span>
                            <a id="footer-source" href="https://github.com/faqpy/faqpy.me" target="_blank" rel="noreferrer noopener" class="footer-link">source</a>
                            <m3e-tooltip for="footer-source" position="above">view on github</m3e-tooltip>
                            <span class="footer-separator">✧</span>
                            <button id="music-toggle" class="footer-link btn-link" aria-label="toggle music">
                                music <Icon name="material-symbols:music-note" id="icon-play" style="font-size: 1em; vertical-align: middle;" /><Icon name="material-symbols:music-off" id="icon-pause" class="is-hidden" style="font-size: 1em; vertical-align: middle;" />
                            </button>
                            <m3e-tooltip for="music-toggle" position="above">toggle background music</m3e-tooltip>
                        </div>
                        <div class="footer-eexto eexto-grid">
                            <a href="https://status.cafe/" target="_blank" rel="noreferrer noopener">
                                <img src="/assets/buttons/statuscafe.png" alt="status.cafe" draggable="false" class="eexto" />
                            </a>
                            <img src="/assets/buttons/anythingbutchrome.gif" alt="no chrome" draggable="false" class="eexto" />
                        </div>
                        <div class="footer-copyright">
                            &copy; 2026 faqpy. made with vsc.
                        </div>
                    </div>
                    <FooterMusic />
                </div>
            </div>
        </footer>
    </div>
    <script>
        import '@m3e/web/shape';
        import '@m3e/web/dialog';
        import '@m3e/web/tooltip';
        import '../scripts/scroll.js';
        import '../scripts/copy-button.js';
        import '../scripts/lastfm.js';
    </script>
</body>

</html>