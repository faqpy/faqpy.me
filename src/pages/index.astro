---
import '../styles/global.css';
import Header from '../components/Header.astro';
import CustomEmoji from '../components/CustomEmoji.astro';
import FooterBoombox from '../components/FooterBoombox.astro';
import { Icon } from 'astro-icon/components';
---

<html lang="en">

<head>
  <Header />
</head>

<body>
  <main class="layout-main">

    <section class="hero-banner">
      <div class="hero-banner-content"></div>
    </section>

    <section class="content-section">
      <nav class="card-jump-nav" aria-label="Jump to site sections">
        <a href="#about">about</a>
        <a href="#socials">socials</a>
        <a href="#friend">friend</a>
        <a href="#games">mmmgemes</a>
        <a href="#notes">notes</a>
        <a href="#newspaper">news</a>
      </nav>
      <div class="content-layout">

        <div class="content-column">

          <section class="card" id="about">
            <div class="card-icon-wrapper">
              <m3e-shape name="soft-burst" class="m3e-icon-bg"
                style="--m3e-shape-container-color:var(--md-sys-color-primary);"></m3e-shape>
              <Icon name="material-symbols:waving-hand" class="card-icon-foreground" />
            </div>
            <div class="profile-details">
              <h1 class="profile-title"><span class="highlight-primary">faqpy</span> です!</h1>
              <p class="text-muted text-small align-up">(a.k.a witchie)</p>
              <ul class="profile-description">
                <li>heya, i'm faqpy
                  <CustomEmoji src="/assets/emojis/miauWhat.webp" name="miau" />
                </li>
                <li>a self-taught web developer (currently studying)</li>
                <li>頭悪いですｗ</li>
              </ul>
              <img src="/assets/images/ralsei-heart.webp" alt="ralsei heart" class="card-image" style="width: 80px;"
                draggable="false" />
            </div>
          </section>

          <section class="card" id="socials">
            <div class="card-icon-wrapper">
              <m3e-shape name="pill" class="m3e-icon-bg"
                style="--m3e-shape-container-color:var(--md-sys-color-primary); transform:rotate(90deg);"></m3e-shape>
              <Icon name="material-symbols:connect-without-contact" class="card-icon-foreground" />
            </div>
            <h2 class="card-heading">socials</h2>
            <div class="interactive-list">
              <a class="list-item" href="https://github.com/faqpy" target="_blank" rel="noreferrer noopener">
                <div class="list-icon">
                  <Icon name="simple-icons:github" />
                </div>
                <div class="list-content">
                  <span class="list-title">github</span>
                  <span class="text-muted text-small">i cnat cod.</span>
                </div>
                <Icon name="material-symbols:chevron-forward" class="list-arrow" />
              </a>
              <a class="list-item" href="https://discord.com/users/277867160796397568" target="_blank"
                rel="noreferrer noopener">
                <div class="list-icon">
                  <Icon name="simple-icons:discord" />
                </div>
                <div class="list-content">
                  <span class="list-title">discord</span>
                  <span class="text-muted text-small">for quick responses</span>
                </div>
                <Icon name="material-symbols:chevron-forward" class="list-arrow" />
              </a>
              <a class="list-item" href="https://x.com/faqpy" target="_blank" rel="noreferrer noopener">
                <div class="list-icon">
                  <Icon name="simple-icons:twitter" />
                </div>
                <div class="list-content">
                  <span class="list-title">twitter</span>
                  <span class="text-muted text-small">dead but i like my tl</span>
                </div>
                <Icon name="material-symbols:chevron-forward" class="list-arrow" />
              </a>
              <a class="list-item" href="https://instagram.com/faqpy" target="_blank" rel="noreferrer noopener">
                <div class="list-icon">
                  <Icon name="simple-icons:instagram" />
                </div>
                <div class="list-content">
                  <span class="list-title">instagram</span>
                  <span class="text-muted text-small">limited to close friends</span>
                </div>
                <Icon name="material-symbols:chevron-forward" class="list-arrow" />
              </a>
            </div>
          </section>

          <section class="card" id="friend">
            <div class="card-icon-wrapper">
              <m3e-shape name="6-sided-cookie" class="m3e-icon-bg"
                style="--m3e-shape-container-color:var(--md-sys-color-primary);"></m3e-shape>
              <Icon name="material-symbols:group" class="card-icon-foreground" />
            </div>
            <h2 class="card-heading">friend</h2>
            <p class="text-muted text-small align-up">one and only</p>
            <div class="interactive-list">
              <a class="list-item" href="https://twixxty.vercel.app" target="_blank" rel="noreferrer noopener">
                <img src="https://github.com/twixxty.png?size=88" alt="twixxty" class="list-avatar" draggable="false" />
                <div class="list-content">
                  <span class="list-title">twixxty</span>
                  <span class="text-muted text-small">ralsei larper but cuter</span>
                </div>
                <Icon name="material-symbols:chevron-forward" class="list-arrow" />
              </a>
            </div>
          </section>

          <section class="card card-image-bg" id="games"
            style="--card-bg-url: url('/assets/images/sonic-and-miku.webp');">
            <div class="card-icon-wrapper">
              <m3e-shape name="gem" class="m3e-icon-bg"
                style="--m3e-shape-container-color:var(--md-sys-color-primary);"></m3e-shape>
              <Icon name="material-symbols:gamepad" class="card-icon-foreground" />
            </div>
            <h2 class="card-heading">i play games
              <CustomEmoji src="/assets/emojis/susie-eager.webp" name="susie-eager" />
            </h2>
            <p class="text-muted text-small align-up">although i rarely play any games now, mmmgemes</p>
            <div class="card-actions inline-fabs">
              <a href="https://steamcommunity.com/id/schizofuck" target="_blank" rel="noreferrer noopener"
                class="fab fab-inline" aria-label="Steam">
                <Icon name="simple-icons:steam" />
              </a>
              <a href="https://www.roblox.com/users/802402672/profile" target="_blank" rel="noreferrer noopener"
                class="fab fab-inline" aria-label="Roblox">
                <Icon name="simple-icons:roblox" />
              </a>
              <a href="https://namemc.com/profile/Faqpy.1" target="_blank" rel="noreferrer noopener"
                class="fab fab-inline" aria-label="Minecraft">
                <Icon name="simple-icons:namemc" />
              </a>
              <a href="https://music.youtube.com/@schizofuck" target="_blank" rel="noreferrer noopener"
                class="fab fab-inline" aria-label="Youtube Music">
                <Icon name="simple-icons:youtubemusic" />
              </a>
            </div>

          </section>

        </div>

        <div class="content-column">

          <section class="card card-image-bg" style="--card-bg-url: url('/assets/images/osaka.webp');" id="notes">
            <div class="card-icon-wrapper icon-secondary">
              <m3e-shape name="burst" class="m3e-icon-bg"
                style="--m3e-shape-container-color:var(--md-sys-color-secondary-container);"></m3e-shape>
              <Icon name="material-symbols:edit-note" class="card-icon-foreground" />
            </div>
            <h2 class="card-heading">notes</h2>
            <p class="text-muted text-small align-up">obsd-sync repo hasn't been initialized yet and probably will never
              be.</p>
            <div class="card-actions">
              <a href="/notes" class="btn-primary btn-primary-blur">
                <Icon name="material-symbols:open-in-new" class="btn-icon" />
                open vault
              </a>
            </div>
          </section>

          <section class="card" id="newspaper">
            <div class="card-icon-wrapper icon-secondary">
              <m3e-shape name="square" class="m3e-icon-bg"
                style="--m3e-shape-container-color:var(--md-sys-color-secondary-container);"></m3e-shape>
              <Icon name="material-symbols:newspaper" class="card-icon-foreground" />
            </div>
            <h2 class="card-heading">newspaper</h2>
            <p class="text-muted text-small align-up">Tuesday, June 23rd, 2026</p>
            <div class="card-article">
              <p>
                studying japanese through anki was really fun but it gets quite boring really quickly, so boring that
                you actually start skipping lessons. this is a problem because it makes it really hard to get back into
                the habit of studying. i guess i'll just have to find a way to make it more fun and interesting so that
                i can keep up with it again.
                <CustomEmoji src="/assets/emojis/tenna-dance.webp" name="tenna-dance" />
              </p>
              <img src="/assets/gifs/susie-eat-melon.webp" alt="susie eating melon" class="card-image gif"
                style="width: 80px;" draggable="false" />
              <p>
                if you're reading this and have any suggestions on how to make studying japanese more fun and
                interesting, please let me know! i'd really appreciate it, really.
                <CustomEmoji src="/assets/emojis/ralsei-tata.webp" name="ralsei-tata" />
              </p>
            </div>
            <img src="/assets/images/cunny.webp" class="card-image" alt="miau miau bunny" draggable="false" />
          </section>

          <section class="card" id="art">
            <img src="/assets/gifs/papyrus-watering.webp" class="card-image gif" alt="papyrus watering"
              draggable="false" />
          </section>

        </div>

      </div>
    </section>
  </main>
  <footer class="site-footer">
    <div class="footer-container">
      <div class="footer-card">
        <button class="fab footer-fab mail" aria-label="contact me" title="mail me!"
          onclick="window.location.href='mailto:hi@faqpy.me'">
          <Icon name="simple-icons:gmail" />
        </button>
        <span class="text-muted text-small"><a href="/license" class="btn-footer">license</a></span>
        <FooterBoombox />
        <button class="fab footer-fab" id="music-toggle" aria-label="toggle music"
          title="Toby Fox - It's Raining Somewhere Else (UNDERTALE)">
          <Icon name="material-symbols:music-note" id="icon-play" />
          <Icon name="material-symbols:music-off" id="icon-pause" class="icon-hidden" />
        </button>
      </div>
    </div>
  </footer>
  <script>
    import '@m3e/web/shape';
  </script>
</body>

</html>