---
import '../styles/global.css';
import Header from '../components/Header.astro';
import CustomEmoji from '../components/CustomEmoji.astro';
import FooterMusic from '../components/FooterMusic.astro';
import EnterScreen from '../components/EnterScreen.astro';
import { Icon } from 'astro-icon/components';
---

<html lang="en">

<head>
    <Header />
</head>

<body>
    <EnterScreen />
    <div id="main-wrapper" style="display: none; opacity: 0; transition: opacity 0.5s ease-in;">
        <main class="layout-main">

            <section class="hero-banner">
                <div class="hero-banner-content"></div>
            </section>

            <section class="content-section">
                <nav class="card-nav" aria-label="Jump to site sections">
                    <a href="#about">about</a>
                    <a href="#socials">socials</a>
                    <a href="#friends">friends</a>
                    <a href="#games">mmmgemes</a>
                    <a href="#notes">notes</a>
                    <a href="#newspaper">news</a>
                </nav>
                <div class="content-layout">

                    <div class="content-column">

                        <section class="card" id="about">
                            <div class="card-icon-wrapper">
                                <m3e-shape name="soft-burst" class="m3e-icon-bg" style="--m3e-shape-container-color:var(--md-sys-color-primary);"></m3e-shape>
                                <Icon name="material-symbols:waving-hand" class="card-icon-foreground" />
                            </div>
                            <div class="profile-details about-card">
                                <h1 class="profile-title"><span>faqpy</span> です!</h1>
                                <p class="card-subtitle">(a.k.a witchie)</p>
                                <ul class="profile-description">
                                    <li>heya, i'm faqpy <CustomEmoji src="/assets/emojis/miauWhat.webp" name="miau" /></li>
                                    <li>a self-taught web developer</li>
                                    <li>頭悪いですｗ</li>
                                </ul>
                                <img src="/assets/images/ralsei-plush-nurse.webp" alt="ralsei heart" class="card-image" style="width: 80px; transform: rotate(180deg);" draggable="false" />
                            </div>
                            <div class="statuscafe" style="margin-top: 0;">
                                <div id="statuscafe-username"></div>
                                <div id="statuscafe-content"></div>
                            </div>
                            <script src="https://status.cafe/current-status.js?name=faqpy" defer></script>

                        </section>

                        <section class="card" id="socials">
                            <div class="card-icon-wrapper">
                                <m3e-shape name="pill" class="m3e-icon-bg" style="--m3e-shape-container-color:var(--md-sys-color-primary); transform:rotate(90deg);"></m3e-shape>
                                <Icon name="material-symbols:connect-without-contact" class="card-icon-foreground" />
                            </div>
                            <h2 class="card-heading">socials</h2>
                            <img src="/assets/gifs/wobble-fw.webp" alt="wobble-favicon" class="card-image free-image">
                            <div class="interactive-list">
                                <a class="list-item" href="https://github.com/faqpy" target="_blank"
                                    rel="noreferrer noopener">
                                    <div class="list-icon">
                                        <Icon name="simple-icons:github" />
                                    </div>
                                    <div class="list-content">
                                        <span class="list-title">github</span>
                                        <span class="list-desc">i cnat cod</span>
                                    </div>
                                    <Icon name="material-symbols:chevron-forward" class="list-arrow" />
                                </a>
                                <a class="list-item" href="https://discord.com/users/277867160796397568" target="_blank" rel="noreferrer noopener">
                                    <div class="list-icon">
                                        <Icon name="simple-icons:discord" />
                                    </div>
                                    <div class="list-content">
                                        <span class="list-title">discord</span>
                                        <span class="list-desc">for quick responses</span>
                                    </div>
                                    <Icon name="material-symbols:chevron-forward" class="list-arrow" />
                                </a>
                                <a class="list-item" href="https://x.com/faqpy" target="_blank" rel="noreferrer noopener">
                                    <div class="list-icon">
                                        <Icon name="simple-icons:twitter" />
                                    </div>
                                    <div class="list-content">
                                        <span class="list-title">twitter</span>
                                        <span class="list-desc">dead but i like my tl</span>
                                    </div>
                                    <Icon name="material-symbols:chevron-forward" class="list-arrow" />
                                </a>
                            </div>
                        </section>

                        <section class="card" id="friends">
                            <div class="card-icon-wrapper">
                                <m3e-shape name="6-sided-cookie" class="m3e-icon-bg" style="--m3e-shape-container-color:var(--md-sys-color-primary);"></m3e-shape>
                                <Icon name="material-symbols:group" class="card-icon-foreground" />
                            </div>
                            <h2 class="card-heading">friends</h2>
                            <p class="card-subtitle">some cool people :3</p>
                            <div class="card-article eexto-grid">
                                <a href="https://twixxt.vercel.app/" title="@twixxty on github" target="_blank" rel="noreferrer noopener">
                                    <img src="/assets/buttons/twixxty.gif" alt="twixxty" draggable="false" class="eexto" />
                                </a>
                                <a href="https://www.nicovideo.jp/watch/sm11509720" title="Nyanyanyanyanyanyanya!" target="_blank" rel="noreferrer noopener">
                                    <img src="/assets/buttons/miau.png" alt="miau" draggable="false" class="eexto" />
                                </a>
                                <a href="/player" title="what am i even doing" data-astro-prefetch="hover">
                                    <img src="/assets/buttons/player-eexto.gif" alt="cute" draggable="false" class="eexto" />
                                </a>
                            </div>
                            <hr class="card-divider">
                            <div class="faqpy-button">
                                <button class="btn-link" id="copy-btn" title="faqpy" aria-label="copy embed code">
                                    <img src="/button.png" alt="faqpy button" draggable="false" class="eexto" />
                                </button>
                                <span class="list-desc" id="copy-label" style="text-align:center;">click to copy</span>
                            </div>
                        </section>

                        <section class="card card-image-bg" id="games" style="--card-bg-url: url('/assets/images/sonic-and-miku.webp');">
                            <div class="card-icon-wrapper">
                                <m3e-shape name="gem" class="m3e-icon-bg" style="--m3e-shape-container-color:var(--md-sys-color-primary);"></m3e-shape>
                                <Icon name="material-symbols:gamepad" class="card-icon-foreground" />
                            </div>
                            <h2 class="card-heading">i play games <CustomEmoji src="/assets/emojis/susie-eager.webp" name="susie-eager" /></h2>
                            <p class="card-subtitle">although i rarely play any games now, mmmgemes</p>
                            <div class="card-actions inline-fabs">
                                <a href="https://steamcommunity.com/id/schizofuck" target="_blank" rel="noreferrer noopener" class="fab fab-inline" aria-label="Steam">
                                    <Icon name="simple-icons:steam" />
                                </a>
                                <a href="https://www.roblox.com/users/802402672/profile" target="_blank" rel="noreferrer noopener" class="fab fab-inline" aria-label="Roblox">
                                    <Icon name="simple-icons:roblox" />
                                </a>
                                <a href="https://namemc.com/profile/Faqpy.1" target="_blank" rel="noreferrer noopener" class="fab fab-inline" aria-label="Minecraft">
                                    <Icon name="simple-icons:namemc" />
                                </a>
                                <a href="https://music.youtube.com/@schizofuck" target="_blank" rel="noreferrer noopener" class="fab fab-inline" aria-label="Youtube Music">
                                    <Icon name="simple-icons:youtubemusic" />
                                </a>
                            </div>

                        </section>

                    </div>

                    <div class="content-column">

                        <section class="card card-image-bg" style="--card-bg-url: url('/assets/images/osaka.webp');" id="notes">
                            <div class="card-icon-wrapper icon-secondary">
                                <m3e-shape name="burst" class="m3e-icon-bg" style="--m3e-shape-container-color:var(--md-sys-color-secondary-container);"></m3e-shape>
                                <Icon name="material-symbols:edit-note" class="card-icon-foreground" />
                            </div>
                            <h2 class="card-heading">notes</h2>
                            <p class="card-subtitle">notes to myself which i never read in the first place ;p</p>
                            <div class="card-actions card-buttons">
                                <a href="/notes" class="btn-primary btn-primary-blur" style="color: var(--md-sys-color-primary);">
                                    open vault <Icon name="material-symbols:open-in-new" class="btn-icon" />
                                </a>
                            </div>
                        </section>

                        <section class="card" id="newspaper">
                            <div class="card-icon-wrapper icon-secondary">
                                <m3e-shape name="square" class="m3e-icon-bg" style="--m3e-shape-container-color:var(--md-sys-color-secondary-container);"></m3e-shape>
                                <Icon name="material-symbols:newspaper" class="card-icon-foreground" />
                            </div>
                            <h2 class="card-heading">newspaper</h2>
                            <p class="card-subtitle">Tuesday, June 23rd, 2026</p>
                            <div class="content-pane">
                                <div class="card-article">
                                    <p>studying japanese through anki was really fun but it gets quite boring really quickly, so boring that you actually start skipping lessons. this is a problem because it makes it really hard to get back into the habit of studying. i guess i'll just have to find a way to make it more fun and interesting so that i can keep up with it again. <CustomEmoji src="/assets/emojis/tenna-dance.webp" name="tenna-dance" /></p>
                                    <img src="/assets/gifs/susie-eat-melon.webp" alt="susie eating melon" class="card-image" style="object-fit: contain; width: 80px;" draggable="false" />
                                    <p>if you're reading this and have any suggestions on how to make studying japanese more fun and interesting, please let me know! i'd really appreciate it, really. <CustomEmoji src="/assets/emojis/ralsei-tata.webp" name="ralsei-tata" /></p><br>
                                </div>
                            </div>
                            <img src="/assets/images/cunny.webp" class="card-image" alt="miau miau bunny" draggable="false" />
                            <div class="news-marquee">
                                <marquee behavior="scroll" direction="left"><span style="font-weight: bold; color: var(--md-sys-color-error-container);">breaking news:</span> meta description my arch enemy confirmed, this thing has given me nightmares &gt;&#58;&#40;</marquee>
                            </div>
                        </section>

                        <section class="card" id="webrings">
                            <h2 class="card-heading">webrings</h2>
                            <div class="webring-list">
                                <div id='gfdkris' class="webring-entry">
                                    <script type="text/javascript" src="https://fabstarotcorner.neocities.org/webring/onionring-variables.js"></script>
                                    <script type="text/javascript" src="https://fabstarotcorner.neocities.org/webring/onionring-widget.js"></script>
                                </div>
                            </div>
                        </section>

                        <section class="card" id="art">
                            <img src="/assets/gifs/papyrus-watering.webp" class="card-image" style="object-fit: contain;" alt="papyrus watering" draggable="false" />
                        </section>

                    </div>

                </div>
            </section>
        </main>
        <footer class="site-footer">
            <div class="footer-container">
                <div class="footer-card">
                    <div class="footer-content">
                        <div class="footer-links">
                            <a href="mailto:hi@faqpy.me" aria-label="contact me" title="mail me!" class="footer-link">mail</a>
                            <span class="footer-separator">✧</span>
                            <a href="/license" class="footer-link">license</a>
                            <span class="footer-separator">✧</span>
                            <a href="https://github.com/faqpy/faqpy.me" target="_blank" rel="noreferrer noopener" class="footer-link">source</a>
                            <span class="footer-separator">✧</span>
                            <button id="music-toggle" class="footer-link btn-link" aria-label="toggle music" title="Toby Fox - The place where it rained (DELTARUNE Chapter 3+4 Soundtrack)">
                                music <Icon name="material-symbols:music-note" id="icon-play" style="font-size: 1em; vertical-align: middle;" /><Icon name="material-symbols:music-off" id="icon-pause" class="is-hidden" style="font-size: 1em; vertical-align: middle;" />
                            </button>
                        </div>
                        <div class="footer-eexto eexto-grid">
                            <a href="https://status.cafe/" title="status.cafe" target="_blank" rel="noreferrer noopener">
                                <img src="/assets/buttons/statuscafe.png" alt="status.cafe" draggable="false" class="eexto" />
                            </a>
                            <img src="/assets/buttons/anythingbutchrome.gif" alt="no chrome" draggable="false" class="eexto" />
                        </div>
                        <div class="footer-copyright">
                            &copy; 2026 faqpy. made with vsc.
                        </div>
                    </div>
                    <FooterMusic />
                </div>
            </div>
        </footer>
    </div>
    <script>
        import '@m3e/web/shape';
    </script>
    <script>
        const copyBtn = document.querySelector('#copy-btn');
        const copyLabel = document.querySelector('#copy-label');
        const embedCode = '<a href="https://faqpy.me" target="_blank" rel="noreferrer noopener"><img src="https://faqpy.me/button.png" alt="faqpy.me" width="88" height="31" /></a>';
        if (copyBtn) {
            copyBtn.addEventListener('click', () => {
                navigator.clipboard.writeText(embedCode).then(() => {
                    if (copyLabel) copyLabel.textContent = 'copied!';
                    setTimeout(() => {
                        if (copyLabel) copyLabel.textContent = 'click to copy';
                    }, 2000);
                });
            });
        }
    </script>
</body>

</html>