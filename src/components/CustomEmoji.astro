---
interface Props {
    src?: string;
    name?: string;
}

const { src = "", name = "emoji" } = Astro.props;
---

<img src={src} alt={name} class="emoji-img" draggable="false" />
<style>
    .emoji-img {
        -webkit-user-select: all;
        user-select: all;
        pointer-events: none;
        height: 1.6em;
        vertical-align: middle;
        margin: 0 2px;
        width: auto;
    }
</style>