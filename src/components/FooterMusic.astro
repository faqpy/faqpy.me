<audio id="boombox-audio" src="/assets/audios/dr_c.mp3" loop preload="none"></audio>

<script>
    const boombox = document.querySelector<HTMLAudioElement>("#boombox-audio");
    const musicToggle = document.querySelector<HTMLButtonElement>("#music-toggle");
    const playIcon = document.querySelector<HTMLElement>("#icon-play");
    const pauseIcon = document.querySelector<HTMLElement>("#icon-pause");

    if (boombox && musicToggle && playIcon && pauseIcon) {
        boombox.volume = 0.3;

        const updateIcons = () => {
            if (boombox.paused) {
                playIcon.classList.add("is-hidden");
                pauseIcon.classList.remove("is-hidden");
            } else {
                playIcon.classList.remove("is-hidden");
                pauseIcon.classList.add("is-hidden");
            }
        };

        musicToggle.addEventListener("click", () => {
            if (boombox.paused) {
                boombox.play().catch(() => {});
            } else {
                boombox.pause();
            }
            updateIcons();
        });

        document.addEventListener('enter-site', () => {
            if (boombox.paused) {
                boombox.play().catch(() => {});
                updateIcons();
            }
        });
    }
</script>